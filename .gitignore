# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Data (large EOPF Zarr products — kept out of git)
*.zarr/
*.zarr.zip
data/s2_dataset/

# E2E data folders — track the structure, ignore the large inputs/products and the regenerable
# driver quicklooks. (The .zarr products under data/output/ are already ignored by `*.zarr/` above;
# the committed result figures live in docs/_static/showcase/.)
data/input/*
!data/input/.gitkeep
!data/input/README.md
data/output/quicklook/*.png

